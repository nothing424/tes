{
  "version": 2,
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://kitsuneid-api-production.up.railway.app/:path*" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=300, stale-while-revalidate=600" }
      ]
    }
  ]
}
